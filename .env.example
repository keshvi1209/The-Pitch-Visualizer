# ─────────────────────────────────────────────────────────────
#  Pitch Visualizer — Environment Configuration
#  Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────────────────

# --- Prompt Engineering (at least one required) ---
# Primary: Google Gemini
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_key_here

# Fallback: Anthropic Claude
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# HuggingFace — Required for image generation (if using HF)
# Get a free token at: https://huggingface.co/settings/tokens
# Free tier supports FLUX.1-schnell and SDXL
HF_TOKEN=hf_...

# OpenAI — Required for DALL-E 3
OPENAI_API_KEY=sk-proj-...

# Stability AI — Required for Stable Diffusion
STABILITY_API_KEY=sk-...

# Image model selection (optional)
# Options: flux-schnell | sdxl | sd21
# Default: flux-schnell (fastest, best free quality)
HF_MODEL=flux-schnell

# Flask settings
FLASK_DEBUG=1
PORT=5000
SECRET_KEY=change-me-in-production
