# ─────────────────────────────────────────────────────────────
#  Pitch Visualizer — Environment Configuration
#  Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────────────────

# Anthropic / Claude — Required for AI prompt engineering
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace — Required for image generation
# Get a free token at: https://huggingface.co/settings/tokens
# Free tier supports FLUX.1-schnell and SDXL
HF_TOKEN=hf_...

# Image model selection (optional)
# Options: flux-schnell | sdxl | sd21
# Default: flux-schnell (fastest, best free quality)
HF_MODEL=flux-schnell

# Flask settings
FLASK_DEBUG=1
PORT=5000
SECRET_KEY=change-me-in-production
